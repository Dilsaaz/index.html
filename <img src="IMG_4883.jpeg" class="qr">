<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Aurex Trade – Account Overview</title>
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>
body{
  margin:0;
  font-family:Arial,Helvetica,sans-serif;
  background:linear-gradient(135deg,#0f2027,#203a43,#2c5364);
  color:#fff;
}
.container{
  max-width:420px;
  margin:auto;
  padding:25px;
}
.header{
  text-align:center;
  margin-bottom:20px;
}
.header h1{
  margin:0;
  letter-spacing:1px;
}
.header p{
  font-size:14px;
  color:#cfcfcf;
}
.card{
  background:rgba(255,255,255,0.08);
  border-radius:12px;
  padding:20px;
}
.row{
  display:flex;
  justify-content:space-between;
  padding:10px 0;
  border-bottom:1px solid rgba(255,255,255,0.1);
  font-size:14px;
}
.row:last-child{border:none;}
.label{color:#d0d0d0;}
.value{font-weight:bold;color:#00ffcc;}
.status{color:#00ff66;font-weight:bold;}
.graph{
  margin-top:20px;
  background:#0b1f2a;
  border-radius:10px;
  padding:15px;
}
.graph-title{
  font-size:13px;
  margin-bottom:10px;
  color:#cfcfcf;
}
svg polyline{
  fill:none;
  stroke:#00ffcc;
  stroke-width:3;
}
.footer{
  margin-top:25px;
  text-align:center;
  font-size:12px;
  color:#bdbdbd;
}
</style>
</head>

<body>

<div class="container">

  <div class="header">
    <h1>AUREX TRADE</h1>
    <p>AI Trading Account (Demo View)</p>
  </div>

  <div class="card">

    <div class="row">
      <span class="label">User ID</span>
      <span class="value" id="uid">AXR00000</span>
    </div>

    <div class="row">
      <span class="label">Wallet Fund</span>
      <span class="value">$<span id="wallet">0</span></span>
    </div>

    <div class="row">
      <span class="label">Account Status</span>
      <span class="status">Active</span>
    </div>

    <div class="row">
      <span class="label">Trade Status</span>
      <span class="value">Live Running</span>
    </div>

  </div>

  <div class="graph">
    <div class="graph-title">AI Trade Performance (Demo)</div>
    <svg width="100%" height="120" viewBox="0 0 300 120">
      <polyline points="0,90 40,70 80,75 120,50 160,55 200,30 240,35 300,20"/>
    </svg>
  </div>

  <div class="footer">
    Demo Account Display Only<br>
    ©️ 2025 Aurex Trade
  </div>

</div>

<script>
const params = new URLSearchParams(window.location.search);
const uid = params.get("uid");
const wallet = params.get("wallet");

if(uid) document.getElementById("uid").innerText = uid;
if(wallet) document.getElementById("wallet").innerText = wallet;
</script>

</body>
</html>
